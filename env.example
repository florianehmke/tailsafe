# Advanced multi-friend reference example.
# If this is your first pair, start from `env.one-friend.example` instead.

TAILSAFE_VERSION=0.2.3
TAILSCALE_DOCKER_TAG=stable
TAILSAFE_IMAGE_NAMESPACE=ghcr.io/pixeljonas/tailsafe
TZ=Europe/Berlin
TS_OUTBOUND_AUTHKEY=tskey-created-on-your-tailnet
TS_OUTBOUND_HOSTNAME=tailsafe-outbound-home-a
TS_ENDPOINT_AUTHKEY_FRIEND_B=tskey-issued-by-friend-b
TS_ENDPOINT_HOSTNAME_FRIEND_B=tailsafe-home-a-endpoint-friend-b
TS_ENDPOINT_AUTHKEY_FRIEND_C=tskey-issued-by-friend-c
TS_ENDPOINT_HOSTNAME_FRIEND_C=tailsafe-home-a-endpoint-friend-c
TAILSAFE_REMOTE_BACKUP_HTTP_PASSWORD_FRIEND_B=friend-b-gave-you-this
TAILSAFE_REMOTE_MAINT_HTTP_PASSWORD_FRIEND_B=friend-b-gave-you-this
TAILSAFE_REMOTE_BACKUP_HTTP_PASSWORD_FRIEND_C=friend-c-gave-you-this
TAILSAFE_REMOTE_MAINT_HTTP_PASSWORD_FRIEND_C=friend-c-gave-you-this
TAILSAFE_INBOUND_BACKUP_HTTP_PASSWORD_FRIEND_B=you-created-this-for-friend-b
TAILSAFE_INBOUND_MAINT_HTTP_PASSWORD_FRIEND_B=you-created-this-for-friend-b
TAILSAFE_INBOUND_BACKUP_HTTP_PASSWORD_FRIEND_C=you-created-this-for-friend-c
TAILSAFE_INBOUND_MAINT_HTTP_PASSWORD_FRIEND_C=you-created-this-for-friend-c
RESTIC_REPOSITORY_PASSWORD=change-me
BACKREST_BIND_PORT=9898
BACKREST_DATA_ROOT=/volume1/tailsafe/backrest
REPO_DATA_ROOT=/volume1/tailsafe/repos
TAILSAFE_STATE_ROOT=/volume1/tailsafe/state
USERDATA_ROOT=/volume1/tailsafe/userdata
SITE_CONFIG_PATH=../config/site.json
